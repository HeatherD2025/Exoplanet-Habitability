generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Planet {
  id            String           @id @default(uuid())
  name          String           @unique
  discoveryYear Int?
  hostStarName  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  traits        PlanetaryTrait[]

  @@index([hostStarName])
  @@index([discoveryYear])
}

enum MassType {
  MEASURED
  CALCULATED
  UNKNOWN
}

model PlanetaryTrait {
  id       String @id @default(uuid())
  planetId String
  planet   Planet @relation(fields: [planetId], references: [id], onDelete: Cascade)

  // general physical data
  planetaryMass   Decimal? @db.Decimal(12, 6) // shown in Earth masses
  planetaryRadius Decimal? @db.Decimal(12, 6) // shown in Earth radius measurements
  massType        MassType @default(UNKNOWN)

  // habitability essential traits
  stellarFlux                  Decimal? @db.Decimal(12, 6) // Earth = 1.0
  orbitalDistance              Decimal? @db.Decimal(12, 6) // AU
  equilibriumTemperatureKelvin Decimal? @db.Decimal(12, 6) // NASA pl_eqt (K)

  // NASA spectroscopy literature counts (no pl_spectype column in ps)
  transmissionSpectroscopyCount  Int? // pl_ntranspec
  eclipseSpectroscopyCount       Int? // pl_nespec
  directImagingSpectroscopyCount Int? // pl_ndispec

  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planetId])
  @@index([planetId, isDefault])
}
